{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Tcom",
  "version": "0.0.2",
  "identifier": "com.thedongcc.tcom",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "title": "Tcom",
        "url": "splashscreen.html",
        "width": 460,
        "height": 400,
        "decorations": false,
        "resizable": false,
        "transparent": false,
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "main",
        "title": "Tcom",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ws://localhost:* http://localhost:* ipc: http://ipc.localhost https://ipc.localhost; img-src 'self' data: https: http: asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
